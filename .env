# ==========================================
# HYZEROX FRONTEND ENVIRONMENT VARIABLES
# Copy this file to .env.local for local dev
# ==========================================

# Base URL for metadata and canonical links
NEXT_PUBLIC_SITE_URL=https://hyzerox.com

# Form Submissions (Resend / SendGrid)
# CONTACT_EMAIL_API_KEY=your_api_key_here

# Payment Gateway (Stripe)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# Live Currency Exchange Rates API (exchangeratesapi.io / openexchangerates)
# EXCHANGE_RATE_API_KEY=your_api_key_here

# Uptime/Status Monitoring (e.g., BetterUptime, Statuspage)
# STATUS_API_ENDPOINT=https://status.hyzerox.com/api/...
